{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build web app",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"problemMatcher": [
				"$tsc",
				"$eslint - stylish"
			],
			"group": "build"
		},
		{
			"label": "List Next app dir",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Get-ChildItem -Force .\\app | Select-Object Name,Mode,Length | Format-Table -AutoSize | Out-String | Write-Output"
			],
			"problemMatcher": []
		},
		{
			"label": "Build web",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "build:web",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Typecheck web",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"-s",
				"typecheck"
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Build web app (one-off)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"-s",
				"build"
			],
			"problemMatcher": [
				"$eslint-stylish",
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Build web app after slot fix",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"-s",
				"build"
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		}
	]
}